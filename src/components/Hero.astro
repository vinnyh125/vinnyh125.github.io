---
// src/components/Hero.astro
import IsometricPC from './IsometricPC.astro';
---

<section
  id="hero"
  class="relative min-h-screen overflow-hidden flex items-center justify-center"
>
  <!-- PC background layer -->
  <div
    id="pc-wrapper"
    class="absolute inset-0 flex items-center justify-center z-0 pointer-events-none"
    style="opacity: 0.15"
  >
    <div class="w-[70vmin] h-[70vmin]">
      <IsometricPC />
    </div>
  </div>

  <!-- Text foreground layer -->
  <div class="relative z-10 flex flex-col items-center justify-center gap-4 px-6 pt-16 text-center">
    <p id="hero-greeting" class="text-xs tracking-widest uppercase text-muted" style="opacity:0">
      Hello, I'm
    </p>
    <h1
      id="hero-name"
      class="text-5xl sm:text-7xl font-bold tracking-tight text-text"
      style="opacity:0"
    >
      Vincent Huang
    </h1>
    <p id="hero-subtitle" class="text-sm tracking-widest uppercase text-muted mt-1" style="opacity:0">
      Software Engineer &middot; Cornell CS '26
    </p>

    <div id="hero-links" class="flex items-center gap-6 mt-6" style="opacity:0">
      <a
        href="https://github.com/vinnyh125"
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted hover:text-text transition-colors duration-200"
        aria-label="GitHub"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
      <a
        href="https://www.linkedin.com/in/vinny-huang/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted hover:text-text transition-colors duration-200"
        aria-label="LinkedIn"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a
        href="https://drive.google.com/file/d/18gIneW-Hn-GyQI5EaESbNuw77jwel6DV/view?usp=sharing"
        target="_blank"
        rel="noopener noreferrer"
        class="text-xs tracking-widest uppercase border border-border px-4 py-2 text-muted hover:text-text hover:border-muted transition-colors duration-200"
        aria-label="Resume"
      >
        Resume
      </a>
    </div>

    <a
      id="hero-arrow"
      href="#experience"
      class="absolute bottom-8 text-muted hover:text-text transition-colors duration-200 animate-bounce"
      aria-label="Scroll down"
      style="opacity:0"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </a>
  </div>
</section>

<script>
  import { createTimeline, stagger } from 'animejs';

  const tl = createTimeline({ autoplay: true, defaults: { ease: 'easeOutExpo' } });

  // Step 1: Case body
  tl.add('#pc-case', {
    opacity: [0, 1],
    scale: [0.85, 1],
    duration: 700,
  });

  // Step 2: Motherboard
  tl.add('#pc-motherboard', {
    opacity: [0, 1],
    translateY: [30, 0],
    duration: 500,
  }, '-=400');

  // Step 3: CPU
  tl.add('#pc-cpu', {
    opacity: [0, 1],
    translateY: [-25, 0],
    duration: 400,
  }, '-=200');

  // Step 4: RAM sticks staggered
  tl.add(['#pc-ram-a', '#pc-ram-b'], {
    opacity: [0, 1],
    translateX: [25, 0],
    duration: 400,
    ease: 'easeOutElastic(1, 0.6)',
    delay: stagger(80),
  }, '-=150');

  // Step 5: GPU
  tl.add('#pc-gpu', {
    opacity: [0, 1],
    translateX: [-35, 0],
    duration: 450,
  }, '-=200');

  // Step 6: SSD
  tl.add('#pc-ssd', {
    opacity: [0, 1],
    translateY: [20, 0],
    duration: 350,
  }, '-=300');

  // Step 7: Text reveal + start parallax after
  tl.add(['#hero-greeting', '#hero-name', '#hero-subtitle', '#hero-links', '#hero-arrow'], {
    opacity: [0, 1],
    translateY: [8, 0],
    duration: 600,
    ease: 'easeOutQuad',
    delay: stagger(80),
    onComplete: startParallax,
  }, '+=100');

  function startParallax() {
    const hero = document.getElementById('hero') as HTMLElement;
    const pcWrapper = document.getElementById('pc-wrapper') as HTMLElement;
    if (!hero || !pcWrapper) return;

    const MAX_X = 20;
    const MAX_Y = 10;
    const LERP = 0.08;

    let targetX = 0, targetY = 0;
    let currentX = 0, currentY = 0;

    hero.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = hero.getBoundingClientRect();
      targetX = ((e.clientX - rect.left) / rect.width  - 0.5) * MAX_X * 2;
      targetY = ((e.clientY - rect.top)  / rect.height - 0.5) * MAX_Y * 2;
    });

    hero.addEventListener('mouseleave', () => {
      targetX = 0;
      targetY = 0;
    });

    function tick() {
      currentX += (targetX - currentX) * LERP;
      currentY += (targetY - currentY) * LERP;
      pcWrapper.style.transform = `translate(${currentX}px, ${currentY}px)`;
      requestAnimationFrame(tick);
    }

    requestAnimationFrame(tick);
  }
</script>
